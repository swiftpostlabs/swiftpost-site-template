{
  "name": "@swiftpost/next-static-template",
  "private": true,
  "type": "module",
  "version": "0.0.1",
  "description": "Batteries included React template",
  "main": "index.js",
  "repository": "git@github.com:swiftpostlab/swiftpost-next-static-template.git",
  "author": "SwiftPost <swiftpostlab@gmail.com>",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace @swiftpost/main dev",
    "build": "yarn workspace @swiftpost/main build",
    "start": "yarn workspace @swiftpost/main start",
    "lint": "turbo lint",
    "lint:ci": "turbo lint --ui stream",
    "lint:fix": "turbo lint:fix --ui stream",
    "typecheck": "yarn tsc --project scripts/tsconfig.json --noEmit && turbo typecheck",
    "typecheck:ci": "yarn tsc --project scripts/tsconfig.json --noEmit && turbo typecheck --ui stream",
    "sync:skills": "agentic-tools skills sync",
    "upgrade:agentic-tools": "yarn upgrade agentic-tools",
    "sync:ai-policy": "node --experimental-strip-types scripts/sync-ai-policy.mts",
    "sync:ai-policy:import-vscode": "node --experimental-strip-types scripts/sync-ai-policy.mts --import-vscode",
    "prepare": "yarn sync:ai-policy"
  },
  "dependencies": {
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "agentic-tools": "github:swiftpostlab/agentic-tools",
    "prettier": "^3.8",
    "turbo": "^2.7",
    "typescript": "^5.9.3"
  }
}
